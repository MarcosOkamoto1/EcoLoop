  }

  @Patch(':id/complete')
  complete(@Param('id') id: string, @Request() req) {
    return this.collectionsService.complete(id, req.user.userId);
  }

  @Get('my')
  findMyCollections(@Request() req) {
    return this.collectionsService.findMyCollections(req.user.userId);
  }
}
